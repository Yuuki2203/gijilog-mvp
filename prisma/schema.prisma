generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Minute {
  id          String     @id @default(uuid())
  userId      String
  title       String
  meetingDate DateTime
  rawText     String
  summary     String
  decisions   Decision[]
  todos       Todo[]
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@index([userId, createdAt])
}

model Decision {
  id       String @id @default(uuid())
  minuteId String
  content  String
  order    Int
  minute   Minute @relation(fields: [minuteId], references: [id], onDelete: Cascade)

  @@index([minuteId])
}

model Todo {
  id       String    @id @default(uuid())
  minuteId String
  content  String
  assignee String?
  dueDate  DateTime?
  isDone   Boolean   @default(false)
  order    Int
  minute   Minute    @relation(fields: [minuteId], references: [id], onDelete: Cascade)

  @@index([minuteId])
}
